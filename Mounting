import {useEffect,useState} from "react"; 
function App() { 
    const [count,setCount]=useState(0); 
 
    useEffect(()=>{ 
      console.log("Mounted"); 
    }) 
 
    useEffect(()=>{ 
        console.log("Count changed",count); 
    },[count]) 
 
      
 
    return ( 
      <div> 
        <h2>Count: {count}</h2> 
        <button onClick={()=>setCount(count+1)}>Increment</button> 
      </div> 
    ) 
} 
 
export default App;
